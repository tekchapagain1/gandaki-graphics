generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Order {
  id        Int     @id @default(autoincrement())
  orderCode String? @unique
  name      String
  email     String?
  phone     String?
  product   String  // T-shirt, Hoodie, Cup
  size      String? // XS, S, M, L, XL, XXL, One Size
  color     String?
  quantity  Int
  designNotes String?
  designFileName String?
  designFilePath String?
  deadline  String?
  status    String  @default("pending") // pending, confirmed, completed, cancelled
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Admin {
  id    Int     @id @default(autoincrement())
  email String  @unique
  passwordHash String
  createdAt DateTime @default(now())
}

model GalleryItem {
  id        Int      @id @default(autoincrement())
  category  String   // T-shirts, Hoodies, Cups
  title     String
  desc      String
  color     String
  accent    String
  image     String
  rating    Int      @default(5)
  customer  String
  review    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

